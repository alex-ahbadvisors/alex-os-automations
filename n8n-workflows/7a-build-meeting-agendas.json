      "type": "n8n-nodes-base.clickUp",
      "typeVersion": 1,
      "position": [880, 300],
      "id": "fetch-existing-desc-001",
      "name": "Fetch Existing Description",
      "credentials": {
        "clickUpOAuth2Api": {
          "id": "WiEsUqUCPM9Xds21",
          "name": "ClickUp Alex Oauth"
        }
