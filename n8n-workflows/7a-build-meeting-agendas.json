    },
    {
      "parameters": {
        "jsCode": "// Prepare input for the Tool workflow\n// Uses index-based matching to combine task data with fetched description\nconst allTasks = $('Extract Task Data').all();\nconst allExisting = $input.all();\nconst results = [];\n\nfor (let i = 0; i < allExisting.length; i++) {\n  const task = allTasks[i]?.json || {};\n  const existing = allExisting[i]?.json || {};\n\n  results.push({\n    eventId: task.eventId,\n    meetingTitle: task.meetingTitle,\n    meetingTime: task.meetingTime,\n    attendees: task.attendees,\n    pass: task.pass,\n    existingAgendaTaskId: task.existingAgendaTaskId,\n    existingDescription: existing.description || existing.content || '',\n    clientName: ''\n  });\n}\n\nreturn results;"
      },
