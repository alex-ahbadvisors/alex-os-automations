    {
      "id": "9a4e7f79-a752-4222-8344-470ec762fab9",
      "name": "Extract Task Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        0
      ],
      "parameters": {
        "jsCode": "  // Extract custom fields from each Relay-created agenda task                                                                                                                          \n  // Convert attendee emails to JSON array format for the Tool workflow\n  // Determine pass (day-before vs day-of) from meeting start time                                                                                                                      \n  const response = $input.first().json;                                                                                                                                                 \n  const tasks = response.tasks || [];\n\n  if (tasks.length === 0) return [];\n\n  const now = new Date();\n  const todayStart = new Date(now);\n  todayStart.setHours(0, 0, 0, 0);\n  const tomorrowStart = new Date(todayStart);\n  tomorrowStart.setDate(tomorrowStart.getDate() + 1);\n\n  const results = [];\n\n  for (const task of tasks) {\n    const cf = {};\n    for (const field of (task.custom_fields || [])) {\n      cf[field.name] = field.value || '';\n    }\n\n    const gCalId = cf['gCal ID'] || cf['gCal Id'] || '';\n    const attendeeEmailsRaw = cf['Attendee Emails'] || cf['Attendee emails'] || '';\n    const attendeeDomains = cf['Attendee email domains'] || cf['Attendee Email Domains'] || '';\n\n    // Convert comma-separated emails to JSON array\n    const attendees = attendeeEmailsRaw\n      .split(',')\n      .map(e => e.trim())\n      .filter(e => e && e.includes('@'))\n      .map(e => ({ email: e.toLowerCase(), displayName: e.split('@')[0] }));\n\n    // Read meeting start time from custom field (populated by Relay)\n    const meetingStartRaw = cf['Meeting Date & Time'] || cf['Meeting Date &amp; Time'] || '';\n    let meetingDateStr = '';\n    if (meetingStartRaw) {\n      // ClickUp date custom fields store as Unix ms\n      const ms = typeof meetingStartRaw === 'number' ? meetingStartRaw : parseInt(meetingStartRaw);\n      meetingDateStr = new Date(ms).toISOString();\n    } else {\n      // Fallback: derive from due_date + 1 day (no time info)\n      const dueDate = task.due_date ? parseInt(task.due_date) : 0;\n      meetingDateStr = new Date(dueDate + 24 * 60 * 60 * 1000).toISOString();\n    }\n\n    const meetingDate = new Date(meetingDateStr);\n    let pass = 'day-before';\n    if (meetingDate < tomorrowStart) {\n      pass = 'day-of'; // Meeting is today\n    }\n\n    // Extract meeting title: strip date prefix like \"[2026-03-04] \"\n    const rawName = task.name || 'Untitled Meeting';\n    const meetingTitle = rawName.replace(/^\\[\\d{4}-\\d{2}-\\d{2}\\]\\s*/, '');\n\n    results.push({\n      eventId: gCalId || task.id,\n      existingAgendaTaskId: task.id,\n      meetingTitle: meetingTitle,\n      meetingTime: meetingDateStr,\n      attendees: JSON.stringify(attendees),\n      attendeeCount: attendees.length,\n      pass: pass,\n      agendaTaskName: task.name\n    });\n  }\n\n  return results;"
      }
    },
