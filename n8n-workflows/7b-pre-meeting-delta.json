      "name": "Check Notes Current",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "// Compare current state against stored state from last refresh\nconst stored = $('Filter Upcoming (30 min)').first().json;\n\n// Current tasks hash\nlet currentTasksHash = '';\ntry {\n  const taskData = $('Check Tasks Current').first().json;\n  const tasks = taskData.tasks || [];\n  currentTasksHash = tasks.map(t => t.id + ':' + (t.status?.status || '')).sort().join('|');\n} catch(e) {}\n\n// Current email timestamp (Missive uses last_activity_at)\nlet currentEmailTs = '';\ntry {\n  const emailData = $('Check Emails Current').first().json;\n  const convos = emailData.conversations || [];\n  if (convos.length > 0) {\n    currentEmailTs = String(convos[0].last_activity_at || '');\n  }\n} catch(e) {}\n\n// Current meeting note ID\nlet currentNoteId = '';\ntry {\n  const noteData = $('Check Notes Current').first().json;\n  currentNoteId = noteData.taskId || noteData.id?.toString() || '';\n} catch(e) {}\n\n// Compare\nconst tasksChanged = currentTasksHash !== (stored.lastTasksHash || '');\nconst emailsChanged = currentEmailTs !== (stored.lastEmailTimestamp || '');\nconst notesChanged = currentNoteId !== (stored.lastMeetingNoteId || '');\n\nif (!tasksChanged && !emailsChanged && !notesChanged) {\n  return []; // Nothing new\n}\n\nconst changes = [];\nif (tasksChanged) changes.push('task status changed');\nif (emailsChanged) changes.push('new email received');\nif (notesChanged) changes.push('new meeting note processed');\n\nreturn {\n  hasChanges: true,\n  changeSummary: changes.join(', '),\n  eventId: stored.eventId,\n  agendaTaskId: stored.agendaTaskId,\n  clientName: stored.clientName,\n  clientListId: stored.clientListId || '',\n  meetingTitle: stored.meetingTitle,\n  meetingTime: stored.meetingTime,\n  attendees: stored.attendees || '[]',\n  pass: 'pre-meeting'\n};"
      },
