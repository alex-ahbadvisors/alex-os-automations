    {
      "parameters": {
        "jsCode": "// Check if we're in business hours (8 AM - 7 PM ET, Mon-Fri)\nconst now = new Date();\nconst etOptions = { timeZone: 'America/New_York' };\nconst etHour = parseInt(now.toLocaleString('en-US', { ...etOptions, hour: 'numeric', hour12: false }));\nconst dayName = now.toLocaleString('en-US', { ...etOptions, weekday: 'short' });\n\nconst isWeekday = !['Sat', 'Sun'].includes(dayName);\nconst isBusinessHours = etHour >= 8 && etHour < 19;\n\nif (!isWeekday || !isBusinessHours) {\n  return [];\n}\n\nreturn {\n  checkTime: now.toISOString()\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [220, 300],
      "id": "check-business-hours-001",
      "name": "Check Business Hours"
    },
    {
      "parameters": {
        "operation": "get",
        "dataTableId": {
          "__rl": true,
          "value": "nwyXScDBE1Sitgiw",
          "mode": "id"
        },
        "filters": {
          "conditions": []
        },
        "limit": 50
      },
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1,
      "position": [440, 300],
      "id": "get-upcoming-agendas-001",
      "name": "Get All Agendas",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "// Filter to agendas where meeting is within next 30 minutes\n// AND not refreshed in the last 20 minutes (avoid rapid re-fires)\nconst now = new Date();\nconst window30min = new Date(now.getTime() + 30 * 60 * 1000);\nconst cooldown20min = new Date(now.getTime() - 20 * 60 * 1000);\n\nconst agendas = $input.all();\nconst upcoming = [];\n\nfor (const item of agendas) {\n  const meetingTime = new Date(item.json.meetingTime);\n  const lastRefreshed = new Date(item.json.lastRefreshed);\n\n  const isUpcoming = meetingTime > now && meetingTime <= window30min;\n  const cooldownPassed = lastRefreshed < cooldown20min;\n  const hasTask = item.json.agendaTaskId && item.json.agendaTaskId !== '';\n\n  if (isUpcoming && cooldownPassed && hasTask) {\n    upcoming.push(item.json);\n  }\n}\n\nif (upcoming.length === 0) return [];\n\nreturn upcoming;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 300],
      "id": "filter-upcoming-001",
      "name": "Filter Upcoming (30 min)"
    },
