        "jsCode": "// Prepare input for the Tool workflow — use stored attendees and clientName\nconst changes = $('Detect Changes').first().json;\nconst existing = $input.first().json;\n\nreturn {\n  eventId: changes.eventId,\n  meetingTitle: changes.meetingTitle,\n  meetingTime: changes.meetingTime,\n  attendees: changes.attendees,\n  pass: 'pre-meeting',\n  existingAgendaTaskId: changes.agendaTaskId,\n  existingDescription: existing.description || existing.content || '',\n  clientName: changes.clientName\n};"
      },
