        "blocksUi": "={\n  \"blocks\": [\n    {\n      \"type\": \"section\",\n      \"text\": {\n        \"type\": \"mrkdwn\",\n        \"text\": \":wave: <@U07ARECGAF8>, *if something needs editing, reply in this thread with your feedback.\"\n      }\n    },\n    { \"type\": \"divider\" },\n    {\n      \"type\": \"rich_text\",\n      \"elements\": [\n        {{ \n          $json.tasks.map((task,i) => ({\n            \"type\": \"rich_text_section\",\n            \"elements\": [\n              { \"type\": \"text\", \"text\":  `[${i+1}] ${task.title}`, \"style\": { \"bold\": true } },\n              { \"type\": \"text\", \"text\": \"\\n\" },\n              { \"type\": \"text\", \"text\": \"Owner: \" },\n              { \"type\": \"text\", \"text\": (task.assignee || \"—\") },\n              { \"type\": \"text\", \"text\": \"\\n\" },\n              { \"type\": \"text\", \"text\": \"Priority: \" },\n              { \"type\": \"text\", \"text\": (task.priority || \"—\") },\n              ...(task.depends_on ? [\n                { \"type\": \"text\", \"text\": \"\\n\" },\n                { \"type\": \"text\", \"text\": \"Depends on: \" },\n                { \"type\": \"text\", \"text\": task.depends_on }\n              ] : []),\n              { \"type\": \"text\", \"text\": \"\\n\\n\" },\n              { \"type\": \"text\", \"text\": (task.description || \"\") },\n              { \"type\": \"text\", \"text\": \"\\n\\n\" }\n            ]\n          }).toJsonString()).join(',') \n        }}\n      ]\n    }\n  ]\n}",
