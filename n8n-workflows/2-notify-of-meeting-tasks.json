        "blocksUi": "={\"blocks\": [\n      {\n          \"type\": \"section\",\n          \"text\": {\n              \"type\": \"mrkdwn\",\n              \"text\": {{ `Approve tasks for ${$('Meeting Note').item.json.name}`.toJsonString() }}\n          }\n      },\n      {{$json.buttons}},\n      {\n        \"type\": \"section\",\n        \"block_id\": \"assign_meeting_project\",\n        \"text\": {\n          \"type\": \"mrkdwn\",\n          \"text\": \"_Project:_\"\n        },\n        \"accessory\": {{ $json.accessory.toJsonString() }}\n      }\n]}",
