    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// n8n Code node (Run Once for Each Item)\n\nconst startOfThread = $input.item.json.messages.find(m => m.thread_ts == m.ts);\n\n// 1) Get Missive draft id from the earlier node\n//    Adjust this path if your field name is different.\nconst followupDraftId =$('Save Followup Draft Id').item.json.followupDraftId\n\n// 2) Build the Missive draft URL\nconst missiveDraftUrl =\n  `https://mail.missiveapp.com/#drafts/conversations/${followupDraftId}`;\n\n// 3) Clone blocks so we can safely mutate them\nconst blocks = JSON.parse(JSON.stringify(startOfThread.blocks || []));\n\n// 4) Find the first actions block and append a new button\nconst actionsBlock = blocks.find(b => b.type === 'actions');\n\nif (actionsBlock) {\n  actionsBlock.elements = actionsBlock.elements\n    .filter(e => e.action_id !=='open_missive_draft')\n    .concat({\n        \"type\": \"button\",\n        \"action_id\": \"open_missive_draft\",\n        \"text\": {\n          \"type\": \"plain_text\",\n          \"text\": \"✉️ Open ack draft\",\n          \"emoji\": true\n        },\n        \"value\": `open_missive_draft_${followupDraftId}`,\n        \"url\": missiveDraftUrl,\n   });\n}\n\nreturn { blocks, ts: startOfThread.ts, };"
      },
