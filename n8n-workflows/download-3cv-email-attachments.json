    {
      "parameters": {
        "jsCode": "// Combine Drive response (webViewLink) with Process Attachments metadata\nvar driveItems = $input.all();\nvar metaItems = $('Process Attachments').all();\nvar results = [];\n\nfor (var i = 0; i < driveItems.length; i++) {\n  var drive = driveItems[i].json;\n  var meta = (i < metaItems.length) ? metaItems[i].json : {};\n  results.push({\n    json: {\n      'Date': meta.date || '',\n      'Subject': meta.subject || '',\n      'From': meta.from || '',\n      'To': meta.to || '',\n      'CC': meta.cc || '',\n      'Attachment Title': meta.attachmentTitle || String(drive.name || ''),\n      'Drive Link': String(drive.webViewLink || drive.webContentLink || ''),\n      'Message ID': meta.messageId || ''\n    }\n  });\n}\n\nreturn results;"
      },
