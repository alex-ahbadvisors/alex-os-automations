    {
      "parameters": {
        "jsCode": "  // Gmail simple:false returns: from/to/cc as objects with .text,\n  // subject as string, date as ISO string. All lowercase.\n  var results = [];\n  var items = $input.all();\n\n  for (var i = 0; i < items.length; i++) {\n    var item = items[i];\n    var binary = item.binary || {};\n    var keys = Object.keys(binary);\n    if (keys.length === 0) continue;\n\n    // Date - ISO string like \"2024-08-30T19:43:47.000Z\"\n    var dateRaw = item.json.date || '';\n    var dateStr = '';\n    if (dateRaw) {\n      try {\n        var d = new Date(dateRaw);\n        if (!isNaN(d.getTime())) {\n          dateStr = d.toLocaleString('en-US', {\n            timeZone: 'America/New_York',\n            year: 'numeric', month: '2-digit', day: '2-digit',\n            hour: '2-digit', minute: '2-digit', hour12: true\n          });\n        }\n      } catch(e) {\n        dateStr = String(dateRaw).substring(0, 30);\n      }\n    }\n\n    // From/To/CC are objects with .text property, or strings\n    var fromRaw = '';\n    if (item.json.from) {\n      fromRaw = (typeof item.json.from === 'object') ? String(item.json.from.text || '') : String(item.json.from);\n    }\n    var toRaw = '';\n    if (item.json.to) {\n      toRaw = (typeof item.json.to === 'object') ? String(item.json.to.text || '') : String(item.json.to);\n    }\n    var ccRaw = '';\n    if (item.json.cc) {\n      ccRaw = (typeof item.json.cc === 'object') ? String(item.json.cc.text || '') : String(item.json.cc);\n    }\n\n    var subject = String(item.json.subject || '');\n    var messageId = String(item.json.id || item.json.messageId || '');\n\n    for (var k = 0; k < keys.length; k++) {\n      var key = keys[k];\n      var binaryItem = binary[key];\n      var originalName = String(binaryItem.fileName || 'attachment');\n      var mimeType = String(binaryItem.mimeType || '');\n      var fileSize = Number(binaryItem.fileSize || 0);\n\n      // Skip inline images with generic names\n      if (mimeType.indexOf('image/') === 0 && originalName.match(/^image[0-9]*\\./)) continue;\n      // Skip Word/Office temp files\n      if (originalName.match(/^~(WRD|\\$)/)) continue;\n      // Skip calendar invites\n      if (originalName.match(/\\.ics$/i) || mimeType === 'text/calendar') continue;\n      // Skip tiny tracking pixels (< 2KB images)\n      if (mimeType.indexOf('image/') === 0 && fileSize > 0 && fileSize < 2000) continue;\n\n      var newBinary = {};\n      newBinary['data'] = binaryItem;\n\n      results.push({\n        json: {\n          messageId: messageId,\n          date: dateStr,\n          from: fromRaw,\n          to: toRaw,\n          cc: ccRaw,\n          subject: subject,\n          attachmentTitle: originalName\n        },\n        binary: newBinary\n      });\n    }\n  }\n\n  return results;"
      },
