      ],
      "parameters": {
        "jsCode": "const allItems = $('Apply Description').all();\nconst changedItems = $('Filter Changed Only').all();\nconst total = allItems.length;\nconst changed = changedItems.length;\n\nconst lines = [\n  '*n8n Workflow Export Complete*',\n  total + ' workflows tracked | ' + changed + ' pushed to GitHub'\n];\n\nif (changed > 0) {\n  lines.push('');\n  lines.push('*Updated:*');\n  for (const item of changedItems) {\n    const url = 'https://github.com/alex-ahbadvisors/alex-os-automations/blob/main/n8n-workflows/' + item.json.filename;\n    lines.push('\\u2022 <' + url + '|' + item.json.name + '>');\n  }\n}\n\nreturn [{ json: { slackMessage: lines.join('\\n') } }];"
      }
    },
    {
      "id": "4199f79c-695f-43b2-901f-4136fd9ba1c5",
      "name": "Apply Description",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1000,
        380
      ],
      "parameters": {
        "jsCode": "const llmItems = $input.all();\nconst originals = $('Parse & Compare').all();\nconst results = [];\n\nfor (let i = 0; i < llmItems.length; i++) {\n  const original = originals[i]?.json || {};\n  const j = llmItems[i].json;\n  // Anthropic returns content as array: content[0].text\n  let response = '';\n  if (j.text) {\n    response = j.text;\n  } else if (j.output) {\n    response = j.output;\n  } else if (Array.isArray(j.content) && j.content[0]?.text) {\n    response = j.content[0].text;\n  } else if (typeof j.content === 'string') {\n    response = j.content;\n  } else if (j.message) {\n    response = j.message;\n  }\n  response = response.trim();\n  if (response.toUpperCase().startsWith('SKIP') || !response) {\n    results.push({ json: { ...original } });\n  } else {\n    results.push({ json: { ...original, description: response } });\n  }\n}\n\nreturn results;"
      }
    },
