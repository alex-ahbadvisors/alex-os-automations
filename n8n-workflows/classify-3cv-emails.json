    {
      "id": "1b5acb7a-1367-4aa4-be15-2bdcbe1047ab",
      "name": "Check Existing Labels",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        0
      ],
      "parameters": {
        "jsCode": "// Check if conversation already has a client label.\n// If yes → skip AI. If no → extract email content for classification.\n//\n// Handles both Missive webhook shapes:\n//   Rule trigger:    body.latest_message\n//   Comment trigger:  body.message\n\nconst webhook = $('3CV Email Webhook').first().json;\nconst body = webhook.body || webhook;\nconst conversation = body.conversation || {};\n\n// Extract message from either webhook shape\nconst message = body.latest_message || body.message || (body.messages || [])[0] || {};\n\n// Current conversation labels\nconst convLabelIds = new Set(\n  (conversation.shared_labels || []).map(l => l.id)\n);\n\n// Filter DataTable to recipient leaf labels (client-eligible)\nconst allLabels = $('Get Missive Labels').all();\nconst clientLabels = allLabels.filter(l => {\n  const j = l.json;\n  return j.category === 'Recipients'\n    && j.is_leaf === 'true'\n    && ['Current Clients', 'Prospects', 'Former clients'].includes(j.sub_category);\n});\n\n// Check if any existing label is already a client label\nconst existingClientLabels = clientLabels\n  .filter(cl => convLabelIds.has(cl.json.label_id))\n  .map(cl => cl.json.label_name);\n\nif (existingClientLabels.length > 0) {\n  return [{ alreadyClassified: true }];\n}\n\n// Extract email content from whichever message shape we got\nconst subject = conversation.subject || message.subject || '';\nconst emailBody = (message.body || message.preview || '')\n  .replace(/<[^>]*>/g, ' ')\n  .replace(/\\s+/g, ' ')\n  .substring(0, 3000);\n\nreturn [{\n  alreadyClassified: false,\n  conversationId: conversation.id,\n  subject: subject,\n  emailBody: emailBody\n}];"
      }
    },
