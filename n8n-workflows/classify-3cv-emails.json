    {
      "id": "c6b5148b-fc28-432f-b7bf-c56fdda09014",
      "name": "Resolve Label IDs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1472,
        0
      ],
      "parameters": {
        "jsCode": "  // Parse Classification Agent structured output                       \n  // Output parser returns: { clients: [...], label_ids: [...] }\n\n  const agentOutput = $('Classification Agent').first().json;\n  const conversationId = $('Check Existing Labels').first().json.conversationId;\n\n  // With structured output parser, output is already an object\n  const output = agentOutput.output || {};\n  const labelIds = output.label_ids || [];\n\n  if (labelIds.length === 0) {\n    return [{ conversationId, labelIds: [], skip: true }];\n  }\n\n  return [{ conversationId, labelIds, skip: false }];"
      }
    },
