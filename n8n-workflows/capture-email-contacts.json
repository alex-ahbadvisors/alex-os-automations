    {
      "parameters": {
        "jsCode": "const m = $('Markdown').first().json.messages;\nconst mine = ['alex@ahbadvisors.com','ahbrownstein@gmail.com','abrownstein@3cventures.com'];\nconst fields = [m.from_field, ...(m.to_fields || []), ...(m.cc_fields || [])].filter(Boolean);\nconst seen = new Set(); const out = [];\nfor (const f of fields) {\n  const email = (f.address || '').toLowerCase();\n  if (!email || mine.includes(email) || seen.has(email)) continue;\n  seen.add(email);\n  out.push({ json: { contact_email: email, contact_name: f.name || email.split('@')[0] }, pairedItem: 0 });\n}\nreturn out;"
      },
