    {
      "parameters": {
        "jsCode": "const m = $('Markdown').first().json.messages;\nconst interactionId = $('Create Interaction').first().json.id;\nconst datePfx = m.delivered_at ? new Date(m.delivered_at*1000).toISOString().slice(0,10).replace(/-/g,'.') : '';\nconst subj60 = (m.subject || '(no subject)').slice(0,60);\nconst isPdf = (a) => {\n  const mt = (a.media_type || '').toLowerCase();\n  const st = (a.sub_type || '').toLowerCase();\n  const name = (a.filename || '').toLowerCase();\n  return mt === 'application/pdf' || (mt === 'application' && st === 'pdf') || name.endsWith('.pdf');\n};\nconst atts = (m.attachments || []).filter(a => isPdf(a) && (a.size == null || a.size > 20000));\nreturn atts.map(a => ({ json: {\n  interaction_id: interactionId,\n  url: a.url,\n  filename: a.filename,\n  media_type: (a.media_type || '') + (a.sub_type ? '/' + a.sub_type : ''),\n  size: a.size,\n  missive_attachment_id: a.id,\n  drive_name: '[' + datePfx + '] ' + subj60 + ' | ' + a.filename,\n}}));"
      },
