    {
      "parameters": {
        "jsCode": "const builds = $('Build Attachments').all().map(i => i.json);\nconst saves = $('Save to Drive').all().map(i => i.json);\nconst extracts = $('Extract from File').all().map(i => i.json);\nconst m = $('Markdown').first().json.messages;\nconst t = m.delivered_at ? new Date(m.delivered_at * 1000).toISOString() : new Date().toISOString();\nconst fromAddr = (m.from_field || {}).address || '';\nconst subj = m.subject || '';\nconst convUrl = (m.conversation || {}).web_url || '';\nreturn builds.map((b, i) => {\n  const driveId = saves[i] ? saves[i].id : null;\n  const text = (extracts[i] && extracts[i].text) ? String(extracts[i].text) : '';\n  const driveLink = driveId ? 'https://drive.google.com/file/d/' + driveId : null;\n  const description = '📎 ' + b.filename + '\\nFrom: ' + fromAddr + ' · Subject: ' + subj + '\\nEmail: ' + convUrl + '\\n---\\n' + text.slice(0, 800);\n  return { json: {\n    interaction_id: b.interaction_id,\n    email_message_id: m.email_message_id,\n    missive_attachment_id: b.missive_attachment_id,\n    source: 'missive',\n    filename: b.filename,\n    media_type: b.media_type,\n    size: b.size,\n    drive_id: driveId,\n    drive_link: driveLink,\n    extracted_text: text,\n    source_event_time: t,\n    subject: subj,\n    from_addr: fromAddr,\n    conversation_url: convUrl,\n    description: description,\n  }};\n});"
      },
