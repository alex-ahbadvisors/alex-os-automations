    {
      "parameters": {
        "jsCode": "const interactionId = $('Create Interaction').first().json.id;\nconst created = {};\ntry { for (const r of $('Create Contacts').all()) {\n  const e = (r.json.emails && r.json.emails[0]) || '';\n  if (e) created[String(e).toLowerCase()] = r.json.id;\n} } catch (e) {}\nconst rows = [];\nfor (const p of $('Resolve').all().map(i => i.json)) {\n  const cid = p.contact_id || created[(p.contact_email || '').toLowerCase()];\n  if (cid) rows.push({ json: {\n    note_id: interactionId,\n    contact_id: cid,\n    match_method: p.contact_id ? 'email' : 'name',\n  }});\n}\nreturn rows;"
      },
