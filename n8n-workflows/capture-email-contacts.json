        "jsCode": "const parts = $('Participants').all().map(i => i.json);\nconst found = $input.all().map(i => i.json).filter(c => c && c.id);\nconst idx = {};\nfor (const c of found) for (const e of (c.emails || [])) idx[String(e).toLowerCase()] = c.id;\nreturn parts.map((p, i) => ({\n  json: {\n    contact_email: p.contact_email,\n    contact_name: p.contact_name,\n    contact_id: idx[(p.contact_email || '').toLowerCase()] || null,\n  },\n  pairedItem: i,\n}));"
